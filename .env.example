# Database (PostgreSQL) — e.g. docker compose in repo root
DATABASE_URL="postgresql://age:age@localhost:5432/age"
# Hetzner Docker Postgres (ops/hetzner/docker-compose.postgres.yml): set POSTGRES_PASSWORD and use same value in DATABASE_URL
# POSTGRES_PASSWORD=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# OAuth (at least one required for sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=

# LLM — OpenRouter (recommended) or OpenAI direct
# Docs: https://openrouter.ai/docs
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_HTTP_REFERER=https://your-public-app-url
# OPENROUTER_APP_TITLE=AGE

# OpenAI direct (used only if OPENROUTER_API_KEY is unset)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# Redis URL for BullMQ (required for queue + worker)
REDIS_URL=redis://127.0.0.1:6379

# Ayrshare — omit for dev (distribution logs only, no live post)
AYRSHARE_API_KEY=

# Stripe (SaaS billing — optional until you enable checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=

# Free tier: max engine runs per workspace per calendar month
AGE_FREE_RUNS_PER_MONTH=10

# If true, every workspace requires manual approval before publish (dashboard).
AGE_REQUIRE_APPROVAL=false

# /api/run throttle per user (per minute), backed by Redis
AGE_API_RUN_POINTS_PER_MINUTE=20

# Workspace invite link expiry (days)
AGE_INVITE_EXPIRY_DAYS=14
